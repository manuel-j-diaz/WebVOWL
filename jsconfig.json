{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "*": ["src/*"]
    },
    "target": "ES6",
    "module": "commonjs",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "deploy"]
}
