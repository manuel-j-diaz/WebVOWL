{
  "name": "webvowl",
  "version": "1.1.7",
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.0",
    "archiver": "^7.0.1",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "html-webpack-plugin": "^5.6.3",
    "jasmine-core": "^4.0.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-commonjs": "^1.0.0",
    "karma-jasmine": "^5.1.0",
    "karma-spec-reporter": "0.0.36",
    "karma-webpack": "^5.0.0",
    "mini-css-extract-plugin": "^2.9.0",
    "rimraf": "^5.0.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.2.0"
  },
  "scripts": {
    "clean":    "rimraf deploy/ webvowl-*.zip",
    "build":    "npm run clean && webpack --mode production",
    "build:dev":"npm run clean && webpack --mode development",
    "release":  "npm run build && rimraf deploy/data/benchmark.json",
    "package":  "npm run build:dev",
    "dev":      "webpack serve --mode development --open",
    "zip":      "node scripts/zip.js",
    "test":     "karma start test/karma.conf.js --single-run",
    "webserver":"npm run package && webpack serve --mode development"
  },
  "license": "MIT",
  "private": true
}
