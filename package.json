{
  "name": "webvowl",
  "version": "1.1.7",
  "dependencies": {
    "d3": "7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/d3": "7.4.3",
    "ajv": "8.18.0",
    "archiver": "7.0.1",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "globals": "15.15.0",
    "html-webpack-plugin": "5.6.6",
    "jsdom": "26.1.0",
    "mini-css-extract-plugin": "2.10.1",
    "rimraf": "5.0.10",
    "style-loader": "4.0.0",
    "vitest": "3.2.4",
    "webpack": "5.105.4",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.3"
  },
  "scripts": {
    "clean":    "rimraf deploy/ webvowl-*.zip",
    "build":    "npm run clean && webpack --mode production",
    "build:dev":"npm run clean && webpack --mode development",
    "release":  "npm run build && rimraf deploy/data/benchmark.json",
    "package":  "npm run build:dev",
    "dev":      "webpack serve --mode development --open",
    "zip":      "node scripts/zip.js",
    "test":     "vitest run",
    "lint":     "eslint src/ test/",
    "webserver":"npm run package && webpack serve --mode development"
  },
  "license": "MIT",
  "private": true
}
