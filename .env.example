# Port on the host machine that WebVOWL will be accessible on.
# Default: 8080
PORT=8080

# External Docker network shared with other stacks (e.g. Fuseki).
# Create it with: docker network create --internal semantic-web
# Default: semantic-web
DOCKER_NETWORK=semantic-web

# Fuseki SPARQL endpoint base URL (Docker-internal hostname).
# Default: http://fuseki:3030
FUSEKI_URL=http://fuseki:3030

# Authorization header value for Fuseki requests.
# Basic auth:  Basic $(echo -n "user:password" | base64)
# Bearer token: Bearer <token>
# API key:     ApiKey <key>   (or whatever scheme your Fuseki expects)
FUSEKI_AUTH_HEADER=Basic <base64-encoded-credentials>
